    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1",
    "qrcode": "^1.5.4"
  }
